{
  "name": "itamarjuniordev/devsocial",
  "description": "DevSocial API - rede social para desenvolvedores com Laravel",
  "type": "project",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^10.0",
    "laravel/sanctum": "^3.3",
    "php-open-source-saver/jwt-auth": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi"
    ]
  },
  "config": {
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
